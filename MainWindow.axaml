<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
		Width="1024" Height="768"
		Background="{DynamicResource SurfaceColor}"
        x:Class="MonitoringSystem.MainWindow"
        Title="Orion">
			

		<DockPanel>
			<!-- Боковая навигация (оставляем как было) -->
			<Border DockPanel.Dock="Left" Width="200" Background="{DynamicResource CardBackgroundBrush}">
				<StackPanel Margin="16">
					<TextBlock Text="MONITOR" FontWeight="Bold" FontSize="18"
							   Foreground="{DynamicResource BrandBrush}" Margin="0,0,0,24"/>

					<RadioButton Content="Dashboard" GroupName="Nav" IsChecked="True" />
					<RadioButton Content="CPU" GroupName="Nav" Margin="0,8,0,0" />
					<RadioButton Content="RAM" GroupName="Nav" Margin="0,8,0,0" />
					<RadioButton Content="Drives" GroupName="Nav" Margin="0,8,0,0" />
					<RadioButton Content="Network" GroupName="Nav" Margin="0,8,0,0" />
				</StackPanel>
			</Border>

			<!-- Основная область -->
			<DockPanel>
				<!-- ШАПКА С КНОПКАМИ -->
				<Border DockPanel.Dock="Top" Height="48"
						Background="{DynamicResource CardBackgroundBrush}"
						BorderBrush="#3A3A3A" BorderThickness="0,0,0,1">

					<Grid ColumnDefinitions="*,Auto,Auto" Margin="16,0">
						<TextBlock Text="System Overview"
								   FontSize="18"
								   FontWeight="SemiBold"
								   VerticalAlignment="Center"/>

						<!-- Кнопка виджета -->
						<Button Grid.Column="1"
								Width="36" Height="36"
								Margin="0,0,8,0"
								ToolTip.Tip="Show Widget"
								Background="Transparent"
								BorderThickness="0"
								Cursor="Hand"
								Click="OpenWidgetButton_OnClick">
							<Button.Content>
								<PathIcon Data="M4,4 L20,4 L20,20 L4,20 Z M8,8 L16,8 L16,16 L8,16 Z"
										  Width="20" Height="20"
										  Foreground="White"/>
							</Button.Content>
						</Button>

						<!-- Кнопка настроек (шестеренка) -->
						<Button Grid.Column="2"
								Width="36" Height="36"
								Background="Transparent"
								BorderThickness="0"
								Cursor="Hand"
								ToolTip.Tip="Settings"
								Click="OpenSettingsButton_OnClick">
							<Button.Content>
								<PathIcon Data="M12,8 L12,10 L14,10 L14,8 Z M10,14 L12,14 L12,12 L10,12 Z M17,8 L19,8 L19,6 L17,6 Z M14,18 L16,18 L16,16 L14,16 Z M19,12 L21,12 L21,10 L19,10 Z M7,14 L9,14 L9,12 L7,12 Z M5,10 L7,10 L7,8 L5,8 Z M4,16 L6,16 L6,14 L4,14 Z M16,4 L18,4 L18,2 L16,2 Z M10,4 L12,4 L12,2 L10,2 Z"
										  Width="20" Height="20"
										  Foreground="White"/>
							</Button.Content>
						</Button>
					</Grid>
				</Border>

				<!-- Контент -->
				<ScrollViewer>
					<ContentControl x:Name="MainContent" Margin="16" />
				</ScrollViewer>
			</DockPanel>
		</DockPanel>
	</Window>

   